# ============================================================
# Backend to ML — Environment variables (NAMUNA)
# ============================================================
# 1. Bu faylni nusxalang: cp .env.example .env
# 2. Quyidagi qiymatlarni o'zingiznikiga almashtiring
# 3. .env fayl .gitignore'da — secret'lar Git'ga tushmaydi
# ============================================================

# ---------- LLM Providers (Oy 5) ----------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
GROQ_API_KEY=...
OPENROUTER_API_KEY=...

# ---------- HuggingFace ----------
HF_TOKEN=hf_...

# ---------- W&B / Tracking ----------
WANDB_API_KEY=...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ---------- MLflow ----------
MLFLOW_TRACKING_URI=http://localhost:5000

# ---------- Vector DB (Oy 5) ----------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ---------- Database (Oy 6) ----------
DATABASE_URL=postgresql://ml:ml@localhost:5432/mldb
REDIS_URL=redis://localhost:6379/0

# ---------- Storage (Oy 6 — DVC remote) ----------
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_REGION=us-east-1
S3_BUCKET=ml-artifacts

# ---------- Kaggle (datasetlar yuklash uchun) ----------
KAGGLE_USERNAME=
KAGGLE_KEY=

# ---------- App config ----------
APP_ENV=development
LOG_LEVEL=INFO
