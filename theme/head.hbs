{{!-- SEO Meta Tags --}}
{{#if (eq language "ru")}}
<meta name="description" content="Путь от Middle Python (Django, DRF, FastAPI) backend разработчика к ML Engineer / MLOps Engineer. 6-месячный практический roadmap.">
<meta name="keywords" content="machine learning, MLOps, Python, Django, FastAPI, backend, ML engineer, deep learning, LLM, RAG, roadmap, на русском, Jahongir Hakimjonov">
{{else if (eq language "en")}}
<meta name="description" content="Roadmap from Middle Python (Django, DRF, FastAPI) backend developer to ML Engineer / MLOps Engineer. 6-month hands-on path.">
<meta name="keywords" content="machine learning, MLOps, Python, Django, FastAPI, backend, ML engineer, deep learning, LLM, RAG, roadmap, English, Jahongir Hakimjonov">
{{else}}
<meta name="description" content="Middle Python (Django, DRF, FastAPI) backend developer uchun ML Engineer / MLOps Engineer bo'lish yo'li. 6 oylik amaliy roadmap — o'zbek tilida.">
<meta name="keywords" content="machine learning, MLOps, Python, Django, FastAPI, backend, ML engineer, deep learning, LLM, RAG, o'zbek tilida, roadmap, Jahongir Hakimjonov">
{{/if}}
<meta name="author" content="Jahongir Hakimjonov">
<meta name="robots" content="index, follow">

{{!-- Canonical URL (har bir til alohida) --}}
{{#if (eq language "ru")}}
<link rel="canonical" href="https://backendtoml.milliytech.uz/ru/{{ path }}">
{{else if (eq language "en")}}
<link rel="canonical" href="https://backendtoml.milliytech.uz/en/{{ path }}">
{{else}}
<link rel="canonical" href="https://backendtoml.milliytech.uz/{{ path }}">
{{/if}}

{{!-- hreflang — multilingual SEO --}}
<link rel="alternate" hreflang="uz" href="https://backendtoml.milliytech.uz/{{ path }}">
<link rel="alternate" hreflang="ru" href="https://backendtoml.milliytech.uz/ru/{{ path }}">
<link rel="alternate" hreflang="en" href="https://backendtoml.milliytech.uz/en/{{ path }}">
<link rel="alternate" hreflang="x-default" href="https://backendtoml.milliytech.uz/{{ path }}">

